{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Launch Github Copilot CLI",
      "type": "shell",
      "command": "bash -c \"copilot $([ '${env:COPILOT_CLI_ALLOW_ALL}' = 'true' ] && echo '--allow-all')\"",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
